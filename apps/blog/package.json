{
  "name": "@rosin-and-rye/blog",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "gen:rss": "node scripts/generate-rss.js",
    "build": "npm run gen:rss && xmlui build --buildMode=INLINE_ALL --flatDist && xmlui zip-dist --source=dist --target=ui.zip",
    "test:screenshot": "npx playwright test",
    "build-optimized": "npx xmlui-optimizer",
    "preview-optimized": "npx serve@latest ./xmlui-optimized-output"
  },
  "dependencies": {
    "@shikijs/langs": "3.4.2",
    "shiki": "^3.3.0",
    "scheduler": "^0.23.2",
    "xmlui": "*",
    "xmlui-search": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@emotion/is-prop-valid": "^1.3.1",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "strip-markdown": "6.0.0",
    "unified": "11.0.5"
  }
}
